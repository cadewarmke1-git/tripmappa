# Copy to .env.local for local development (never commit .env.local)

# Client (Vite — referenced via import.meta.env.VITE_*)
VITE_GOOGLE_MAPS_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server (Vercel serverless — referenced via process.env.*, never prefix secrets with VITE_)
ANTHROPIC_KEY=
NREL_API_KEY=
MAPQUEST_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Twilio SMS (serverless — api/send-sms-otp.js only)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567
