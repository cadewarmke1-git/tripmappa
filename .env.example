# ══════════════════════════════════════════════════════════════
# MINIMUM LOCAL DEV (client + basic API)
# Copy to .env.local and fill in values.
# ══════════════════════════════════════════════════════════════
# Required for maps autocomplete and routing in the browser:
VITE_GOOGLE_MAPS_KEY=
# Required for auth (sign-in, saved trips):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Required for server routes (use same Google key or a server-restricted key):
GOOGLE_MAPS_API_KEY=
# Required for trip generation and credits:
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_KEY=

# ══════════════════════════════════════════════════════════════
# OPTIONAL — enable when testing specific features
# ══════════════════════════════════════════════════════════════
SUPABASE_ANON_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_VOYAGER_PRICE_ID=
STRIPE_VOYAGER_ANNUAL_PRICE_ID=
STRIPE_TRAILBLAZER_PRICE_ID=
STRIPE_TRAILBLAZER_ANNUAL_PRICE_ID=
STRIPE_PAYMENT_METHOD_CONFIGURATION=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
RESEND_API_KEY=
TRIPMAPPA_EMAIL_FROM=
EMAIL_FROM=
TRIPMAPPA_SITE_URL=
SITE_URL=
HERE_ACCESS_KEY_ID=
HERE_ACCESS_KEY_SECRET=
NREL_API_KEY=
EIA_API_KEY=
INSTACART_LOCATION_CODE=
INSTACART_STUB_PHONE=
CRON_SECRET=
ADMIN_USER_IDS=
NODE_ENV=
VERCEL_ENV=
