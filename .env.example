# Copy to .env.local for local development (never commit .env.local)

# Client (Vite — referenced via import.meta.env.VITE_*)
VITE_GOOGLE_MAPS_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server (Vercel serverless — referenced via process.env.*, never prefix secrets with VITE_)
ANTHROPIC_KEY=
NREL_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (serverless — checkout, webhooks, billing portal)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_VOYAGER_PRICE_ID=
STRIPE_TRAILBLAZER_PRICE_ID=
# Optional — Stripe Payment Method Configuration ID
STRIPE_PAYMENT_METHOD_CONFIGURATION=

# Email (Resend — welcome, trial reminders, plan emails)
RESEND_API_KEY=
TRIPMAPPA_EMAIL_FROM=
# Fallback sender if TRIPMAPPA_EMAIL_FROM is unset
EMAIL_FROM=

# Site URLs and cron
TRIPMAPPA_SITE_URL=
SITE_URL=
CRON_SECRET=

# Maps and routing
HERE_API_KEY=
# Optional — server can read HERE key from Vite env in local dev
VITE_HERE_API_KEY=
# Server-side Google Maps (also accepts VITE_GOOGLE_MAPS_KEY via googleKey.js)
GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_API_KEY=

# Fuel and grocery
EIA_API_KEY=
# Stub default available if unset
INSTACART_LOCATION_CODE=
# Stub default available if unset
INSTACART_STUB_PHONE=

# Admin (server only)
# Comma-separated Supabase user IDs — skip Founder slot claim; permanent Trailblazer
ADMIN_USER_IDS=

# Twilio SMS (serverless — api/send-sms-otp.js, SOS, live location)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# Dev and CI — not needed in production
SMOKE_BASE_URL=
SMOKE_SKIP_TIPS=
