{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/router?path=$1" },
    { "source": "/live/:token", "destination": "/index.html" },
    { "source": "/collab/:token", "destination": "/index.html" },
    { "source": "/pricing", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/terms", "destination": "/index.html" },
    { "source": "/auth/callback", "destination": "/index.html" },
    { "source": "/profile", "destination": "/index.html" },
    { "source": "/profile/:path*", "destination": "/index.html" },
    { "source": "/((?!api/|assets/|favicon\\.svg|manifest\\.json|og-image\\.png|hero-mountain\\.jpg|robots\\.txt|sitemap\\.xml).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/trial-jobs", "schedule": "0 15 * * *" },
    { "path": "/api/cron/cache-cleanup", "schedule": "0 4 * * 0" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://maps.googleapis.com https://maps.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://maps.googleapis.com https://api.stripe.com; frame-src https://js.stripe.com; object-src 'none'; base-uri 'self'" }
      ]
    }
  ]
}
